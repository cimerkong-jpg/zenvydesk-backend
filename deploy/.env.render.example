# Render Environment Variables for ZenvyDesk API
# Add these in the Render Dashboard under Environment Variables

# Application Configuration
APP_NAME=ZenvyDesk API
APP_ENV=production
APP_BASE_URL=https://api.zenvydesk.site
FRONTEND_BASE_URL=https://zenvydesk.site

# Facebook OAuth Configuration
# Get these from: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_REDIRECT_URI=https://api.zenvydesk.site/auth/facebook/callback
FACEBOOK_SCOPES=public_profile,email

# Database Configuration
# SQLite works on Render but data is ephemeral (resets on redeploy)
# For persistent data, consider upgrading to PostgreSQL
DATABASE_URL=sqlite:///./zenvydesk.db

# Session Configuration
SESSION_EXPIRY_MINUTES=15

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Or let Render auto-generate this
SECRET_KEY=your_secret_key_here_or_let_render_generate
