# Production Environment Configuration for ZenvyDesk API
# Copy this file to /opt/zenvydesk-api/.env and fill in actual values

# Application Configuration
APP_NAME=ZenvyDesk API
APP_ENV=production
APP_BASE_URL=https://api.zenvydesk.site
FRONTEND_BASE_URL=https://zenvydesk.site

# Facebook OAuth Configuration
# Get these from: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your_production_facebook_app_id
FACEBOOK_APP_SECRET=your_production_facebook_app_secret
FACEBOOK_REDIRECT_URI=https://api.zenvydesk.site/auth/facebook/callback
FACEBOOK_SCOPES=public_profile,email

# Database Configuration
# For production, consider PostgreSQL instead of SQLite:
# DATABASE_URL=postgresql://username:password@localhost/zenvydesk
DATABASE_URL=sqlite:///./zenvydesk.db

# Session Configuration
SESSION_EXPIRY_MINUTES=15

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_STRING_MINIMUM_32_CHARACTERS
